{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "BiomedWritingBench Entry Metadata Schema",
  "description": "Schema for metadata.json in each test case directory",
  "type": "object",
  "required": ["id", "title", "published_doi", "published_venue"],
  "properties": {
    "id": {
      "type": "string",
      "description": "Unique identifier (e.g., 'genomics_001', 'dna-foundation-models')"
    },
    "title": {
      "type": "string"
    },
    "biorxiv_doi": {
      "type": ["string", "null"],
      "description": "bioRxiv DOI (10.1101/...)"
    },
    "published_doi": {
      "type": ["string", "null"],
      "description": "Published journal DOI"
    },
    "published_venue": {
      "type": ["string", "null"]
    },
    "published_year": {
      "type": ["integer", "null"]
    },
    "authors": {
      "type": "array",
      "items": {"type": "string"}
    },
    "category": {
      "type": "string",
      "enum": ["genomics", "bioinformatics", "drug_discovery", "neuroscience", "immunology", "clinical", "cancer_biology", "structural_biology", "cell_biology", "epidemiology", "methods"]
    },
    "subcategory": {
      "type": ["string", "null"]
    },
    "paper_type": {
      "type": "string",
      "enum": ["benchmark", "methods", "clinical", "clinical_validation", "atlas", "dataset", "research", "review"]
    },
    "format": {
      "type": "string",
      "default": "single-column"
    },
    "ground_truth_citation_count": {
      "type": ["integer", "null"],
      "description": "Number of references in the published paper"
    },
    "ground_truth_figure_count": {
      "type": ["integer", "null"],
      "description": "Number of figures in the published paper"
    },
    "ground_truth_table_count": {
      "type": ["integer", "null"],
      "description": "Number of tables in the published paper"
    },
    "difficulty": {
      "type": "string",
      "enum": ["easy", "medium", "hard"]
    },
    "notes": {
      "type": "string"
    }
  }
}
